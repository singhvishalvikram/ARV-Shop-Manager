# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ─── Node ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ─── Databases (generated; never commit) ──────────────────
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ─── Secrets & environment ────────────────────────────────
.env
.env.*
!.env.example
*.drive_config.json

# ─── Generated databases (the served JSON in */data/ is a deployment
#     artifact and MUST stay tracked, so only the DB dir is ignored) ──
customer-view/db/

# ─── Editor / OS backups & cruft ──────────────────────────
*.bak
*.bak[0-9]
*.backup
*.backup[0-9]
*.orig
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────
.vscode/
.idea/

# ─── Misc ─────────────────────────────────────────────────
backups/
/tmp/
