<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shop Manager - Inventory & Sales Tracker</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#2196F3">
</head>
<body>
    <!-- Android-style Navigation Drawer -->
    <div class="drawer-overlay" id="drawerOverlay"></div>
    <nav class="drawer" id="navigationDrawer">
        <div class="drawer-header">
            <h2>📦 Shop Manager</h2>
            <button class="drawer-close" onclick="closeDrawer()">&times;</button>
        </div>
        <ul class="drawer-menu">
            <li><a href="#" onclick="selectDrawerItem('dashboard', event)">📊 Dashboard</a></li>
            <li><a href="#" onclick="selectDrawerItem('items', event)">📦 Inventory</a></li>
            <li><a href="#" onclick="selectDrawerItem('sales', event)">💰 Sales</a></li>
            <li><a href="#" onclick="selectDrawerItem('camera', event)">📷 Add Item</a></li>
        </ul>
    </nav>

    <div class="container">
        <!-- Header with Menu Button -->
        <header>
            <button class="menu-btn" onclick="openDrawer()">☰</button>
            <h1>📦 Shop Manager</h1>
            <div class="header-info">
                <span id="onlineStatus" class="online-badge">● Online</span>
                <button id="installBtn" class="btn-small" style="display:none;">Install App</button>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- Dashboard Tab -->
            <section id="dashboard" class="tab-content active">
                <h2>Dashboard</h2>
                <div class="dashboard-grid">
                    <div class="dashboard-card">
                        <h3>Total Items</h3>
                        <p class="big-number" id="totalItems">0</p>
                    </div>
                    <div class="dashboard-card">
                        <h3>Total Stock</h3>
                        <p class="big-number" id="totalStock">0</p>
                    </div>
                    <div class="dashboard-card">
                        <h3>Stock Value</h3>
                        <p class="big-number" id="stockValue">₹0</p>
                    </div>
                    <div class="dashboard-card">
                        <h3>Today's Revenue</h3>
                        <p class="big-number" id="todayRevenue">₹0</p>
                    </div>
                </div>
                <div class="chart-container">
                    <h3>Low Stock Items</h3>
                    <ul id="lowStockList" class="item-list"></ul>
                </div>
            </section>

            <!-- Items Tab -->
            <section id="items" class="tab-content">
                <h2>Inventory</h2>
                <div class="search-bar">
                    <input type="text" id="searchInput" placeholder="Search items..." class="search-field">
                </div>
                <div id="itemsList" class="items-grid"></div>
            </section>

            <!-- Sales Tab -->
            <section id="sales" class="tab-content">
                <h2>Sales</h2>
                <div class="sales-panel">
                    <h3>Record a Sale</h3>
                    <div class="form-group">
                        <label>Select Item:</label>
                        <select id="saleItemSelect" class="form-control">
                            <option value="">-- Choose Item --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantity Sold:</label>
                        <input type="number" id="saleQuantity" class="form-control" min="1" value="1">
                    </div>
                    <button onclick="recordSale()" class="btn-primary">Record Sale</button>
                </div>
                <div class="sales-history">
                    <h3>Today's Sales</h3>
                    <ul id="salesList" class="sales-list"></ul>
                </div>
            </section>

            <!-- Camera Tab -->
            <section id="camera" class="tab-content">
                <h2>Add Item with Photo</h2>
                <div class="camera-container">
                    <!-- Camera Preview -->
                    <div class="camera-preview">
                        <video id="cameraPreview" autoplay playsinline></video>
                        <div class="camera-controls">
                            <button id="startCameraBtn" class="btn-secondary">Start Camera</button>
                            <button id="captureCameraBtn" class="btn-primary" style="display:none;">📸 Capture</button>
                            <button id="stopCameraBtn" class="btn-secondary" style="display:none;">Stop Camera</button>
                        </div>
                    </div>

                    <!-- Captured Image Preview -->
                    <div id="imagePreview" class="image-preview" style="display:none;">
                        <img id="capturedImage" src="">
                        <div class="preview-controls">
                            <button id="retakeBtn" class="btn-secondary">Retake</button>
                            <button id="useImageBtn" class="btn-primary">Use This Image</button>
                        </div>
                    </div>

                    <!-- Item Form -->
                    <form id="itemForm" class="item-form">
                        <div class="form-group">
                            <label>Item Name *</label>
                            <input type="text" name="name" required class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Type</label>
                            <input type="text" name="type" class="form-control" placeholder="e.g., Grocery, Electronics">
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <textarea name="description" class="form-control" placeholder="Item details..."></textarea>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Price (₹)</label>
                                <input type="number" name="price" step="0.01" class="form-control">
                            </div>
                            <div class="form-group">
                                <label>Quantity</label>
                                <input type="number" name="quantity" value="1" class="form-control">
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Location</label>
                            <input type="text" name="location" class="form-control" placeholder="Shelf, Bin, etc.">
                        </div>
                        <input type="hidden" name="image_base64" id="imageBase64">
                        <button type="submit" class="btn-primary btn-block">Add Item</button>
                    </form>
                </div>
            </section>
        </main>
    </div>

    <!-- Modal for item details -->
    <div id="itemModal" class="modal">
        <div class="modal-content">
            <span class="modal-close">&times;</span>
            <div id="itemDetails"></div>
        </div>
    </div>

    <script>
        // Register service worker
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/static/js/sw.js').catch(() => {});
        }
    </script>
    <script src="/static/js/app.js"></script>
</body>
</html>
