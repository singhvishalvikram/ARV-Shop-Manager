<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Shop Manager</title>
<link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
<div id="app">
  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h1>📦 Shop Manager</h1>
      <button class="close-sidebar" onclick="toggleSidebar()">&times;</button>
    </div>
    <nav class="sidebar-nav">
      <a class="nav-item active" data-view="dashboard" onclick="switchView('dashboard')">
        <span>📊</span> Dashboard
      </a>
      <a class="nav-item" data-view="items" onclick="switchView('items')">
        <span>📋</span> All Items
      </a>
      <a class="nav-item" data-view="add" onclick="switchView('add')">
        <span>➕</span> Add Item
      </a>
    </nav>
  </aside>
  <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

  <!-- Main -->
  <main class="main">
    <!-- Top Bar -->
    <header class="topbar">
      <button class="menu-btn" onclick="toggleSidebar()">☰</button>
      <div class="topbar-title" id="topbarTitle">Dashboard</div>
      <div class="topbar-spacer"></div>
    </header>

    <div class="content">
      <!-- ── Dashboard ── -->
      <section id="view-dashboard" class="view active">
        <div class="stats-grid" id="statsGrid">
          <div class="stat-card"><div class="stat-num" id="statTotal">0</div><div class="stat-label">Total Items</div></div>
          <div class="stat-card"><div class="stat-num" id="statTypes">0</div><div class="stat-label">Categories</div></div>
          <div class="stat-card"><div class="stat-num" id="statAvgPrice">₹0</div><div class="stat-label">Avg Price</div></div>
          <div class="stat-card"><div class="stat-num" id="statStockValue">₹0</div><div class="stat-label">Stock Value</div></div>
        </div>
        <div class="card">
          <h3>Type Breakdown</h3>
          <div id="typeBreakdown"><p class="muted">No items yet</p></div>
        </div>
        <div class="card">
          <h3>Recently Added</h3>
          <div id="recentItems"><p class="muted">No items yet</p></div>
        </div>
      </section>

      <!-- ── Items List ── -->
      <section id="view-items" class="view">
        <div class="search-bar">
          <input type="text" id="searchInput" placeholder="Search by name, type, or description..." oninput="debounceSearch()">
          <button onclick="searchItems()">🔍</button>
        </div>
        <div class="items-toolbar">
          <span id="itemCount">0 items</span>
        </div>
        <div id="itemsList" class="items-list"></div>
        <div class="pagination" id="pagination"></div>
      </section>

      <!-- ── Add / Edit Item ── -->
      <section id="view-add" class="view">
        <h2 id="formTitle">Add New Item</h2>
        <form id="itemForm" onsubmit="saveItem(event)">
          <input type="hidden" id="itemId">
          <div class="form-group">
            <label>Item Name *</label>
            <input type="text" id="itemName" required placeholder="e.g. Organic Basmati Rice">
          </div>
          <div class="form-group">
            <label>Type / Category</label>
            <input type="text" id="itemType" placeholder="e.g. Grocery, Electronics">
          </div>
          <div class="form-group">
            <label>Description</label>
            <textarea id="itemDesc" rows="3" placeholder="Full description of the item..."></textarea>
          </div>
          <div class="form-group">
            <label>Price (₹)</label>
            <input type="number" id="itemPrice" step="0.01" min="0" placeholder="0.00">
          </div>
          <div class="form-group">
            <label>Image URL (optional)</label>
            <input type="text" id="itemImage" placeholder="https://example.com/photo.jpg">
          </div>
          <div class="form-group">
            <label>Location / Shelf (optional)</label>
            <input type="text" id="itemLocation" placeholder="e.g. Aisle 3, Rack 2">
          </div>
          <div class="form-actions">
            <button type="submit" class="btn-primary" id="formSubmit">Save Item</button>
            <button type="button" class="btn-secondary" onclick="resetForm()">Cancel</button>
          </div>
        </form>
      </section>

      <!-- ── Item Detail ── -->
      <section id="view-detail" class="view">
        <button class="btn-text" onclick="switchView('items')">← Back to Items</button>
        <div id="itemDetail"></div>
      </section>
    </div>
  </main>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

<script src="/static/js/app.js"></script>
</body>
</html>
