# Copy to .env and adjust per environment. NEVER commit the real .env.
# Standards: GUARDRAILS §1.4 (Environment & Secret Management).

# ── Shop Manager (Flask backend) ──────────────────────────
# All default to repo-relative paths if unset, so the app runs anywhere.
SHOP_DB_PATH=
SHOP_IMAGES_DIR=

# ── Google Drive auto-backup ──────────────────────────────
AUTO_BACKUP_SCRIPT=
BACKUP_DIR=
DRIVE_CONFIG=
GDRIVE_FOLDER_ID=

# ── Secrets (move out of source code — see server.js AUTH_SECRET) ──
# Set a strong random value in real environments; do not reuse the
# hardcoded 'cv_secret_key_2026' that currently lives in the code.
AUTH_SECRET=
