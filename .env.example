# Copy to .env and adjust per environment. NEVER commit the real .env.
# Standards: GUARDRAILS §1.4 (Environment & Secret Management).

# ── Shop Manager (Flask backend) ──────────────────────────
# All default to repo-relative paths if unset, so the app runs anywhere.
SHOP_DB_PATH=
SHOP_IMAGES_DIR=

# ── Google Drive auto-backup ──────────────────────────────
AUTO_BACKUP_SCRIPT=
BACKUP_DIR=
DRIVE_CONFIG=
GDRIVE_FOLDER_ID=

# ── Secrets (move out of source code — see server.js AUTH_SECRET) ──
# Set a strong random value in real environments; do not reuse the
# hardcoded 'cv_secret_key_2026' that currently lives in the code.
AUTH_SECRET=
# Session lifetime (days) for issued bearer tokens.
SESSION_TTL_DAYS=30

# ── Google Sign-In (OIDC, optional) — see ADR-004 ─────────
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Google login is ENABLED only when client id + secret + redirect uri + AUTH_SECRET
# are all set; otherwise the routes are not mounted and Authlib is not required.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in the console, e.g.
# https://app.example.com/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=
# Where the browser lands after a successful login; the session token is
# appended as #token=... for the PWA to read. e.g. https://app.example.com/
OAUTH_SUCCESS_REDIRECT=/
