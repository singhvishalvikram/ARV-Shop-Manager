<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/gap"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/card_corner"
    app:cardElevation="0dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/row_qty"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_qty_ok"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/row_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/on_bg"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/row_qty"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/row_meta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/on_bg_muted"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/row_name"
            app:layout_constraintStart_toEndOf="@id/row_qty"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/row_flags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/row_meta"
            app:layout_constraintStart_toEndOf="@id/row_qty"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/row_sell"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="@dimen/touch_target"
            android:text="@string/sell"
            app:layout_constraintTop_toBottomOf="@id/row_flags"
            app:layout_constraintStart_toEndOf="@id/row_qty"
            android:layout_marginStart="8dp"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/row_delete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="@dimen/touch_target"
            android:text="@string/delete"
            android:textColor="@color/danger_red"
            app:layout_constraintTop_toTopOf="@id/row_sell"
            app:layout_constraintStart_toEndOf="@id/row_sell" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
