<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="StatTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@color/surface</item>
        <item name="android:padding">16dp</item>
        <item name="android:minHeight">88dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="StatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/on_bg</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="StatLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/on_bg_muted</item>
        <item name="android:textSize">13sp</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>

    <style name="FormField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/touch_target</item>
        <item name="android:textColor">@color/on_bg</item>
        <item name="android:textColorHint">@color/on_bg_muted</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>
</resources>
